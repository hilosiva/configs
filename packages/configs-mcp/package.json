{
  "name": "configs-mcp",
  "version": "0.1.0",
  "description": "MCP server for @hilosiva/configs — linting rules guide for Biome, Stylelint, Markuplint",
  "license": "MIT",
  "author": "Shibata Hironori",
  "keywords": [
    "biome",
    "stylelint",
    "markuplint",
    "MCP",
    "linter"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hilosiva/configs.git",
    "directory": "packages/configs-mcp"
  },
  "bugs": "https://github.com/hilosiva/configs/issues",
  "homepage": "https://github.com/hilosiva/configs",
  "bin": {
    "configs-mcp": "./dist/index.mjs"
  },
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('./dist', {recursive:true,force:true})\"",
    "build": "tsup-node",
    "dev": "tsup-node --watch"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "provenance": false,
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.25.0"
  }
}
