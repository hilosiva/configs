  "exports": {
    ".": "./index.js",
    "./astro": "./astro.js",
    "./wp": "./wp.js"
  },
  "files": [
    "index.js",
    "astro.js",
    "wp.js"
  ],
  "license": "MIT",
  "author": "Shibata Hironori",
  "keywords": [
    "markuplint",
    "markuplint-config"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hilosiva/configs.git",
    "directory": "packages/markuplint-config"
  },
  "bugs": "https://github.com/hilosiva/configs/issues",
